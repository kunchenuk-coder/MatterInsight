{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/reset-password", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/upload.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/get-upload-url.ts": {
      "memory": 512,
      "maxDuration": 15
    }
  }
}
